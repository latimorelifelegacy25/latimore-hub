{
  "regions": ["iad1"],
  "functions": {
    "app/api/fillout/route.ts": { "maxDuration": 15 },
    "app/api/reports/**":       { "maxDuration": 20 }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" }
      ]
    }
  ]
}
