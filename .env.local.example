# ─── Database (Supabase Pooler URL) ──────────────────────────────
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres?pgbouncer=true&connection_limit=1"

# ─── Fillout Webhook Secret (HMAC signing secret) ─────────────────
FILLOUT_SECRET="your_fillout_signing_secret"

# ─── Booking Webhook Secret (protect /api/booking/notify) ─────────
BOOKING_WEBHOOK_SECRET="set_a_long_random_secret"

# ─── Google Analytics 4 ──────────────────────────────────────────
GA4_ID="G-XXXXXXXXXX"

# ─── Google OAuth (Admin Login) ──────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
NEXTAUTH_URL="https://latimorelifelegacy.com"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# Optional: lock admin access to specific emails (comma-separated)
ADMIN_EMAILS="jackson1989@latimorelegacy.com"
# Optional: allow Gmail sign-in for local development only
ALLOW_GMAIL_DEV="false"

# ─── Public Base URL (used in emails) ────────────────────────────
NEXT_PUBLIC_BASE_URL="https://latimorelifelegacy.com"

# ─── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
NOTIFY_TO="leads@latimorelegacy.com"
THANKYOU_FROM="Latimore Life & Legacy <hello@latimorelegacy.com>"

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL="info"
