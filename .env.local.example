# ─── Database (Supabase Pooler URL) ──────────────────────────────
DATABASE_URL="postgresql://postgres:[password]@[host]:5432/postgres?pgbouncer=true&connection_limit=1"

# ─── Fillout Webhook Secret ───────────────────────────────────────
FILL0UT_SECRET="your_fillout_signing_secret"

# ─── Google Analytics 4 ──────────────────────────────────────────
GA4_ID="G-XXXXXXXXXX"

# ─── Google OAuth (Admin Login) ──────────────────────────────────
GOOGLE_CLIENT_ID="your_google_client_id"
GOOGLE_CLIENT_SECRET="your_google_client_secret"
NEXTAUTH_URL="https://latimorehub.vercel.app"
NEXTAUTH_SECRET="run: openssl rand -base64 32"

# ─── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxx"
NOTIFY_TO="leads@latimorelegacy.com"
THANKYOU_FROM="Latimore Life & Legacy <hello@latimorelegacy.com>"

# ─── Logging ─────────────────────────────────────────────────────
LOG_LEVEL="info"
